# Backend API origin — server-side only (proxy.ts + Server Components).
# Never exposed to the browser; the browser calls same-origin /api/*.
API_BASE_URL="http://localhost:3001"

# Terminal WebSocket endpoint on the API server (browser connects directly,
# authorized by a short-lived ticket). Genuinely public, so NEXT_PUBLIC.
NEXT_PUBLIC_WS_URL="ws://localhost:3001/api/terminal"
