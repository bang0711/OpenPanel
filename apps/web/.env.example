# Backend API origin — server-side only (proxy.ts + Server Components).
# Never exposed to the browser; the browser calls same-origin /api/*.
API_BASE_URL="http://localhost:3001"

# Terminal WebSocket endpoint on the API server. The browser connects to it
# directly (authorized by a short-lived ticket), so it must be reachable from
# the browser — not a Docker-internal hostname.
#
# Read at RUNTIME by the terminal page (a Server Component) and passed to the
# client as a prop. Deliberately not NEXT_PUBLIC_*: that would inline it into
# the client bundle at build time and freeze it into the published image.
TERMINAL_WS_URL="ws://localhost:3001/api/terminal"
