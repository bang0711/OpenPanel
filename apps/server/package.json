{
  "name": "@openpanel/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build --compile --minify-whitespace --minify-syntax --external cpu-features --outfile dist/op-server src/cli.ts",
    "start": "dist/op-server serve",
    "seed": "tsx scripts/seed-admin.ts",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/openapi": "^1.4.15",
    "@openpanel/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "elysia": "^1.4.29",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@types/node": "^20",
    "@types/ssh2": "^1.15.5",
    "eslint": "^9",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
