# Copy to .env and fill in. Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# PostgreSQL database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/open_panel"

# Better Auth — session signing + terminal-ticket HMAC (32 bytes base64)
BETTER_AUTH_SECRET=""

# AES-256-GCM key for SSH credentials at rest (32 bytes base64)
OPENPANEL_ENC_KEY=""

# HTTP port for this API server
PORT="3001"

# The browser-facing web origin. Single source of truth for CORS, Better Auth
# trusted origins, and its public base URL (cookie scope + redirect URLs).
# It is the WEB app's URL (:3000) — auth is reached same-origin at /api/auth/*
# and proxied here — NOT this server's port (:3001).
WEB_ORIGIN="http://localhost:3000"

# Optional admin seed (bun run seed)
SEED_EMAIL="admin@openpanel.local"
SEED_PASSWORD="admin12345"
