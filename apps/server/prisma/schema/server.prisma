// Application: registered remote SSH servers.

model Server {
  id              String   @id @default(uuid())
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name            String
  host            String
  port            Int      @default(22)
  username        String
  authType        String // 'password' | 'key'
  secretEnc       String // AES-256-GCM blob (password or private key)
  passphraseEnc   String? // optional, for encrypted keys
  hostFingerprint String? // pinned SHA256 host key (TOFU)
  osId            String? // /etc/os-release ID, e.g. 'debian' (drives the distro icon)
  osName          String? // /etc/os-release PRETTY_NAME, e.g. 'Debian GNU/Linux 12 (bookworm)'
  tags            String[] @default([])
  createdAt       DateTime @default(now())

  permissions   ServerPermission[]
  metricSamples MetricSample[]
  alertRules    AlertRule[]
  backupJobs    BackupJob[]

  @@map("server")
}
