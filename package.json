{
  "name": "openpanel",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"bun --filter=@openpanel/web dev\" \"bun --filter=@openpanel/server dev\"",
    "dev:web": "bun --filter=@openpanel/web dev",
    "dev:server": "bun --filter=@openpanel/server dev",
    "build": "bun --filter=@openpanel/web build",
    "start": "concurrently -n web,api -c blue,green \"bun --filter=@openpanel/web start\" \"bun --filter=@openpanel/server start\"",
    "seed": "bun --filter=@openpanel/server seed",
    "db:generate": "bun --filter=@openpanel/server db:generate",
    "db:migrate": "bun --filter=@openpanel/server db:migrate"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "@prisma/engines",
    "prisma",
    "sharp",
    "ssh2",
    "unrs-resolver"
  ]
}
