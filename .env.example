# Copy to .env (or .env.local) and fill in. Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# SQLite database
DATABASE_URL="file:./dev.db"

# Better Auth — session signing + terminal-ticket HMAC (32 bytes base64)
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# AES-256-GCM key for SSH credentials at rest (32 bytes base64)
OPENPANEL_ENC_KEY=""

# Web terminal websocket bridge
OPENPANEL_WS_PORT="3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"

# Optional admin seed (bun run seed)
SEED_EMAIL="admin@openpanel.local"
SEED_PASSWORD="admin12345"
